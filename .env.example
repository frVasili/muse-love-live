DISCORD_TOKEN=
DATA_DIR=./data
YOUTUBE_API_KEY=

############
# Optional #
############

# Public Spotify URLs work without these. Keep them blank unless you want the
# official Spotify API as a backup when Spotify's public web data changes.
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# ROTATING_STATUS_ENABLED=true
# ROTATING_SPOTIFY_PLAYLIST_ID=
# ROTATING_STATUS_INTERVAL_SECONDS=90
# ROTATING_STATUS_REFRESH_MINUTES=360

# CACHE_LIMIT=2GB

# ENABLE_SPONSORBLOCK=true
# SPONSORBLOCK_TIMEOUT=5    # Delay (in mn) before retrying when SponsorBlock server are unreachable.
# YT_DLP_PATH=yt-dlp
# YT_DLP_AUTO_UPDATE=true

